# WIMI application data (user databases, media, plugins) — never commit
app_data/
# wimi-test (CDP regression suite) writes its own isolated app_data dir
# so live tests don't trample the developer's real data.
app_data_test/
*.db-shm
*.db-wal
*.lbdb

# wimi-test failure artifacts (screenshots, console + network logs) —
# regenerated on every CI run, uploaded as an artifact for 14 days.
pytest_artifacts/

# User databases (but keep schema files)
/databases/*.db
!/databases/schema/

