amily":"Loranthus","fontSize":14,"roughness":1,"constraints":[{"id":"set-size","width":"text","height":"text"}],"text":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"A. ACE inhibitor"}]}]},"horzAlign":"left","vertAlign":"top"},{"id":"adlj9IzYju4NDK8_90cPx","type":"Box","parent":"Q8MUUK2qr-yaCA5f5vwKG","name":"Reflection Section","left":20.39,"top":235.04,"width":760,"height":85,"strokeColor":"$slate4","strokeWidth":2,"fontFamily":"Loranthus","roughness":1,"corners":[8,8,8,8]},{"id":"tQyj34EiNqN-X5xgQ0RdI","type":"Text","parent":"Q8MUUK2qr-yaCA5f5vwKG","name":"Reflection Label","left":35.39,"top":247.04,"width":63,"height":15,"strokeWidth":2,"fillStyle":"none","fontColor":"$sage10","fontFamily":"Loranthus","fontSize":11,"roughness":1,"constraints":[{"id":"set-size","width":"text","height":"text"}],"text":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"REFLECTION"}]}]},"horzAlign":"left","vertAlign":"top"},{"id":"fPtFqjngnSUV-9impEbnn","type":"Text","parent":"Q8MUUK2qr-yaCA5f5vwKG","name":"Reflection Text","left":35.39,"top":268.04,"width":707,"height":52,"strokeWidth":2,"fillStyle":"none","fontColor":"$sky12","fontFamily":"Loranthus","fontSize":14,"roughness":1,"constraints":[{"id":"set-size","width":"text","height":"text"}],"text":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"I confused the mechanism of action between ACE inhibitors and ARBs. I knew that both affect the renin-angiotensin system, but I mixed up which one blocks the receptor vs. which one inhibits the enzyme. I need to create a clear mental model distinguishing these two drug classes."}]}]},"wordWrap":true,"horzAlign":"left","vertAlign":"top"},{"id":"QATjEtFMctmqQbpPblrFO","type":"Box","parent":"Q8MUUK2qr-yaCA5f5vwKG","name":"Explanation Section","left":20.39,"top":330.04,"width":760,"height":95,"strokeColor":"$slate4","s