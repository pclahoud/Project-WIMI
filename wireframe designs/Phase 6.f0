ipt":"(do\n  (def! l (. shape :left))\n  (def! r (. shape :right))\n  (def! t (. shape :top))\n  (def! b (. shape :bottom))\n  (def! g 1)\n  (def! seed (. shape :getSeed))\n  (def! c (. shape :corners))\n  (def! h 32)\n  (def! yc (+ t (/ h 2)))\n  (def! buttons (. shape :getPropertyValue \"Buttons\"))\n  (. canvas :strokeRoundRect (- l g) (- t g) (+ r g) (+ b g) c seed)\n  (. canvas :line l (+ t h) r (+ t h) (+ seed 1))\n  (if buttons\n    (do \n      (. canvas :ellipse (+ l 14) (- yc 5) (+ l 24) (+ yc 5) (+ seed 2))\n      (. canvas :ellipse (+ l 32) (- yc 5) (+ l 42) (+ yc 5) (+ seed 3))\n      (. canvas :ellipse (+ l 50) (- yc 5) (+ l 60) (+ yc 5) )+ seed 4)))))"}],"corners":[12,12,12,12],"textEditable":false},{"id":"Ke9Icg6eSzo95MGiwSIO7","type":"Text","parent":"hm2GnYscFpe8j4HDT2tZ3","name":"Self Assessment Label","left":29.61,"top":897.21,"width":225,"height":19,"strokeWidth":2,"fillStyle":"none","fontColor":"$sage10","fontFamily":"Loranthus","fontSize":14.689720426143495,"roughness":1,"constraints":[{"id":"set-size","width":"text","height":"text"}],"text":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","marks":[{"type":"textStyle","attrs":{"color":"$gray9","fontFamily":"","fontSize":"","fontWeight":""}}],"text":"Time Spent vs Difficulty Analysis"}]}]},"horzAlign":"left","vertAlign":"top"}],"name":"Analytics Dashboard - Part 2 (Heatmap, Goals, Reflection)","enable":false,"pageOrigin":[27.442597484865587,241.40014738177774],"pageScale":0.6951528192795795}]}